# ─── Stripe Keys ────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_... / pk_test_...) for development
# Swap to live keys (sk_live_... / pk_live_...) when going live

STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_YOUR_PUBLISHABLE_KEY

# ─── Stripe Webhook Secret ───────────────────────────────────────────────────
# Get this from: https://dashboard.stripe.com/webhooks
# 1. Click "Add endpoint"
# 2. URL: https://yourdomain.com/api/webhook
# 3. Events to listen for: checkout.session.completed
# 4. After saving, reveal the "Signing secret" — paste it here

STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ─── Supabase (Artworks Database) ────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# NEXT_PUBLIC_SUPABASE_URL       — Project URL (safe to expose, but we only use it server-side)
# SUPABASE_SERVICE_ROLE_KEY      — service_role key. SERVER-ONLY. Bypasses RLS.
#                                  Never commit, never import into client components.

NEXT_PUBLIC_SUPABASE_URL=https://REPLACE.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Sign up free at: https://resend.com
# 1. Go to API Keys → Create API Key
# 2. Go to Domains → Add Domain → verify lagartadvisory.com
# 3. Paste the key below

RESEND_API_KEY=re_REPLACE_WITH_YOUR_API_KEY

# ─── App URL ─────────────────────────────────────────────────────────────────
# Optional — the API auto-detects the correct URL from request headers.
# Only set this if you need to override it explicitly.
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
